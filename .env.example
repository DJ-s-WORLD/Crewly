# Copy to ".env" in the PROJECT ROOT (same folder as vite.config.ts — NOT inside src/).
# Vite only exposes variables prefixed with VITE_
# Do not use NEXT_PUBLIC_*; those are for Next.js, not Vite.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Optional: Postgres connection URI to auto-create tables (npm run db:sync).
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use Session mode / direct (port 5432), not pooler, for DDL. Replace [YOUR-PASSWORD].
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional: Supabase CLI only (deploy functions / db push). Never commit a real token.
# Create at https://supabase.com/dashboard/account/tokens — then: npx supabase login
# Or: SUPABASE_ACCESS_TOKEN=sbp_...
