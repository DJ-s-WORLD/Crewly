{
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@supabase/supabase-js": ["../../node_modules/@supabase/supabase-js"],
      "@supabase/supabase-js/cors": ["../../node_modules/@supabase/supabase-js/dist/cors.d.mts"]
    }
  },
  "include": ["./**/*.ts"]
}
